# =============================================================================
# dart-backend-architecture — API Requests
# Compatible with JetBrains HTTP Client and VS Code REST Client
# =============================================================================

@baseUrl       = http://localhost:8080
@contentType   = application/json

# -- Credentials (fill after signup/login) ------------------------------------

@apiKey       = GCMUDiuY5a7WvyUNt9n3QztToSHzK7Uj
@accessToken  = eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9..Jw8m9AR3aN49lKBhhI02tuLtsevBWweMi02a4wBtP10v8heGFklxMK3w3hkvw9gWva6Aix-NSlUr8NXMLVTW6g
@refreshToken = <refresh_token>

# -- Pagination defaults -------------------------------------------------------

@pageNumber    = 1
@pageItemCount = 10


# =============================================================================
# Health
# =============================================================================

### Readiness probe
GET {{baseUrl}}/readyz
#x-api-key: {{apiKey}}


# =============================================================================
# Auth
# =============================================================================

### Signup
POST {{baseUrl}}/v1/signup/basic
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "name": "Jane Doe",
  "email": "jane@example.com",
  "password": "Jane@2026",
  "profile_pic_url": "https://example.com/avatar.png"
}

### Signup — minimal (no avatar)
POST {{baseUrl}}/v1/signup/basic
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "name": "John Doe",
  "email": "john@example.com",
  "password": "John@2026"
}

### Login
POST {{baseUrl}}/v1/login/basic
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "email": "jane@example.com",
  "password": "Jane@2026"
}

### Refresh token
POST {{baseUrl}}/v1/token/refresh
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "refresh_token": "{{refreshToken}}"
}

### Logout
DELETE {{baseUrl}}/v1/logout
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}


# =============================================================================
# Profile
# =============================================================================

### Get my profile
GET {{baseUrl}}/v1/profile/my
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get public profile by id
GET {{baseUrl}}/v1/profile/public/id/01JQKZ9P0000000000000000
x-api-key: {{apiKey}}

### Update profile
PUT {{baseUrl}}/v1/profile
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "name": "Jane Updated",
  "profile_pic_url": "https://example.com/new-avatar.png"
}

### Update profile — name only
PUT {{baseUrl}}/v1/profile
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "name": "Jane Renamed"
}


# =============================================================================
# Blogs — Public
# =============================================================================

### Get blog by slug
GET {{baseUrl}}/v1/blogs/url?endpoint=my-first-blog-post
x-api-key: {{apiKey}}

### Get blog by id
GET {{baseUrl}}/v1/blogs/id/01JQKZ9P0000000000000000
x-api-key: {{apiKey}}

### Get blogs by tag (paginated)
GET {{baseUrl}}/v1/blogs/tag/dart?pageNumber={{pageNumber}}&pageItemCount={{pageItemCount}}
x-api-key: {{apiKey}}

### Get blogs by author id
GET {{baseUrl}}/v1/blogs/author/id/01JQKZ9P0000000000000000
x-api-key: {{apiKey}}

### Get latest blogs (paginated)
GET {{baseUrl}}/v1/blogs/latest?pageNumber={{pageNumber}}&pageItemCount={{pageItemCount}}
x-api-key: {{apiKey}}

### Get similar blogs by id
GET {{baseUrl}}/v1/blogs/similar/id/01JQKZ9P0000000000000000
x-api-key: {{apiKey}}


# =============================================================================
# Blogs — Writer
# =============================================================================

### Create blog (draft)
POST {{baseUrl}}/v1/blogs/writer
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "title": "Getting Started with Dart Isolates",
  "description": "A deep dive into Dart isolate architecture for backend services.",
  "text": "Dart isolates share no memory and communicate via message passing...",
  "tags": ["dart", "backend", "isolates"],
  "blog_url": "getting-started-with-dart-isolates",
  "img_url": "https://example.com/cover.png",
  "score": 0
}

### Create blog — minimal (no image)
POST {{baseUrl}}/v1/blogs/writer
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "title": "Minimal Blog Post",
  "description": "Short description.",
  "text": "Content goes here.",
  "tags": ["dart"],
  "blog_url": "minimal-blog-post"
}

### Update blog
PUT {{baseUrl}}/v1/blogs/writer/id/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}
x-api-key: {{apiKey}}

{
  "title": "Updated Title",
  "tags": ["dart", "updated"]
}

### Submit blog for review
PUT {{baseUrl}}/v1/blogs/writer/submit/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Withdraw blog from review
PUT {{baseUrl}}/v1/blogs/writer/withdraw/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Delete blog (writer)
DELETE {{baseUrl}}/v1/blogs/writer/id/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get my submitted blogs
GET {{baseUrl}}/v1/blogs/writer/submitted/all
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get my published blogs
GET {{baseUrl}}/v1/blogs/writer/published/all
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get my drafts
GET {{baseUrl}}/v1/blogs/writer/drafts/all
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get my blog by id (writer view)
GET {{baseUrl}}/v1/blogs/writer/id/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}


# =============================================================================
# Blogs — Editor
# =============================================================================

### Publish blog
PUT {{baseUrl}}/v1/blogs/editor/publish/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Unpublish blog
PUT {{baseUrl}}/v1/blogs/editor/unpublish/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Delete blog (editor)
DELETE {{baseUrl}}/v1/blogs/editor/id/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get all published blogs (editor view)
GET {{baseUrl}}/v1/blogs/editor/published/all
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get all submitted blogs (editor view)
GET {{baseUrl}}/v1/blogs/editor/submitted/all
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get all drafts (editor view)
GET {{baseUrl}}/v1/blogs/editor/drafts/all
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}

### Get blog by id (editor view)
GET {{baseUrl}}/v1/blogs/editor/id/01JQKZ9P0000000000000000
Authorization: Bearer {{accessToken}}
x-api-key: {{apiKey}}
