# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Server ───────────────────────────────────────────────────
PORT=8080
MAX_REQUEST_BODY_BYTES=1048576    # 1 MB
WORKER_COUNT=0                    # 0 = auto (cpu count)

# ── Database ─────────────────────────────────────────────────
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://dba:dba@localhost:5432/dba?sslmode=disable
DB_PORT=5432
DB_POOL_SIZE=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── NATS ─────────────────────────────────────────────────────
# Leave empty to disable NATS (NoOpEventBus will be used instead)
NATS_URL=nats://localhost:4222
NATS_PORT=4222

# ── JWT ──────────────────────────────────────────────────────
# Option A: file path (local dev, keys mounted as files)
# Generate with:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Option B — inline PEM (containers, secrets managers like Vault / AWS Secrets)
# Uncomment and paste PEM content directly. Takes priority over PATH if set.
#JWT_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
#JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

JWT_ACCESS_TOKEN_EXPIRY=3600        # seconds — 1 hour
JWT_REFRESH_TOKEN_EXPIRY=2592000    # seconds — 30 days

# ── OpenTelemetry ────────────────────────────────────────────
# Leave empty to disable telemetry (no OTLP collector required)
OTEL_ENDPOINT=http://localhost:4317

# ── Environment ──────────────────────────────────────────────
# development | production
ENVIRONMENT=development
