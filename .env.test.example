# Test environment configuration
# Copy to .env.test and adjust for your local setup:
#   cp .env.test.example .env.test
#
# Used when running integration tests locally (outside Docker).
# The Docker test environment (docker-compose.test.yml) injects
# these values directly and does not read this file.

# ── Server ───────────────────────────────────────────────────
PORT=8081
MAX_REQUEST_BODY_BYTES=1048576
WORKER_COUNT=0

# ── Database ─────────────────────────────────────────────────
# Separate test database — never points to dev data
DATABASE_URL=postgres://dba_test:dba_test@localhost:5432/dba_test?sslmode=disable
DB_PORT=5433
DB_POOL_SIZE=5

# ── Redis ────────────────────────────────────────────────────
# Shared Redis instance is fine for tests, keys are isolated by test setup
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── NATS ─────────────────────────────────────────────────────
# Disabled in tests — event publishing uses NoOpEventBus
NATS_URL=
NATS_PORT=4222

# ── JWT ──────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=2592000

# ── OpenTelemetry ────────────────────────────────────────────
# Disabled in tests: no collector required
OTEL_ENDPOINT=

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=test
